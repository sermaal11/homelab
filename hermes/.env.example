HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_PORT=9119
HERMES_DATA_DIR=/data/homelab/hermes/data
HERMES_API_SERVER_KEY=change_me_generate_with_openssl_rand_hex_32

# Optional: you can configure the model inside Hermes instead.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Optional: Telegram can also be configured inside Hermes after first boot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# Optional: Home Assistant MCP/API access can be configured after first boot.
HOMEASSISTANT_TOKEN=

# Grafana is optional in the first boot. Leave the token empty until needed.
GRAFANA_URL=http://grafana:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# Optional Honcho memory sidecar. Disabled unless COMPOSE_PROFILES=honcho.
# Honcho is built from source because upstream does not publish a Docker Hub image.
# With HONCHO_EMBED_MESSAGES=false, no paid embedding provider is required yet.
COMPOSE_PROFILES=
HONCHO_GIT_REF=main
HONCHO_API_BIND=127.0.0.1
HONCHO_API_PORT=8000
HONCHO_POSTGRES_PASSWORD=change_me_generate_with_openssl_rand_hex_32
HONCHO_POSTGRES_DATA_DIR=/data/homelab/hermes/honcho/postgres
HONCHO_REDIS_DATA_DIR=/data/homelab/hermes/honcho/redis
HONCHO_AUTH_USE_AUTH=false
HONCHO_LOG_LEVEL=INFO
HONCHO_OPENAI_BASE_URL=https://api.groq.com/openai/v1
HONCHO_GROQ_MODEL=llama-3.3-70b-versatile
HONCHO_EMBED_MESSAGES=false

TZ=Europe/Madrid
