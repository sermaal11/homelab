HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_PORT=9119
HERMES_DATA_DIR=/data/homelab/hermes/data
HERMES_API_SERVER_KEY=change_me_generate_with_openssl_rand_hex_32

# Optional: you can configure the model inside Hermes instead.
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Optional: Telegram can also be configured inside Hermes after first boot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# Optional: Home Assistant MCP/API access can be configured after first boot.
HOMEASSISTANT_TOKEN=

# Grafana is optional in the first boot. Leave the token empty until needed.
GRAFANA_URL=http://grafana:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=

TZ=Europe/Madrid
