HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_PORT=9119
HERMES_DATA_DIR=/data/homelab/hermes/data
HERMES_API_SERVER_KEY=change_me_generate_with_openssl_rand_hex_32

# Use either OpenRouter or OpenAI-compatible credentials.
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Telegram bot credentials from BotFather and your allowed Telegram user ID.
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_ALLOWED_USERS=change_me_telegram_user_id
TELEGRAM_HOME_CHANNEL=

# Home Assistant long-lived access token for MCP/API access.
HOMEASSISTANT_TOKEN=change_me

# Grafana is optional in the first boot. Leave the token empty until needed.
GRAFANA_URL=http://grafana:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=

TZ=Europe/Madrid
