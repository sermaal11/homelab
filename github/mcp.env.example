# Copy this file to github/mcp.env and keep the real file private.
# Create a GitHub Personal Access Token with only the scopes you need.

GITHUB_PERSONAL_ACCESS_TOKEN=

# Default toolsets from GitHub MCP are: context, repos, issues, pull_requests, users.
# This wrapper adds actions for CI visibility. Use "default" for a narrower setup
# or "default,actions,code_security,secret_protection" if you need security tools.
GITHUB_TOOLSETS=default,actions

GITHUB_MCP_IMAGE=ghcr.io/github/github-mcp-server:latest

# Optional, only for GitHub Enterprise Server / ghe.com data residency.
# GITHUB_HOST=https://github.example.com
